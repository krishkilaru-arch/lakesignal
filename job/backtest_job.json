{
  "name": "lakesignal_daily_backtest",
  "format": "MULTI_TASK",
  "tasks": [
    {
      "task_key": "backtest",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/krish.kilaru@lumenalta.com/lakesignal/notebooks/03_backtest",
        "base_parameters": {
          "catalog": "lakesignal",
          "schema": "core"
