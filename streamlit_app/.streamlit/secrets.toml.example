# Copy this file to .streamlit/secrets.toml and fill in your values.
# For Streamlit Community Cloud, paste these into the app's Secrets settings.
# NEVER commit secrets.toml to git.

[databricks]
host = "https://dbc-XXXXX.cloud.databricks.com"   # Your Databricks workspace URL
http_path = "/sql/1.0/warehouses/XXXXX"             # SQL Warehouse HTTP path
client_id = "your-service-principal-client-id"       # Service principal application ID
client_secret = "your-service-principal-secret"      # Service principal OAuth secret
model_endpoint = "databricks-claude-sonnet-4"        # Foundation Model API endpoint
