# Copy this file to .streamlit/secrets.toml and fill in your values.
# For Streamlit Community Cloud, paste these into the app's Secrets settings.
# NEVER commit secrets.toml to git.

[databricks]
host = "https://dbc-XXXXX.cloud.databricks.com"   # Your Databricks workspace URL
http_path = "/sql/1.0/warehouses/XXXXX"             # SQL Warehouse HTTP path

# ── Auth: pick ONE of the two options below ──

# Option 1: Personal Access Token (simplest — good for testing)
token = "dapi..."

# Option 2: Service Principal OAuth (production — comment out token above)
# client_id = "your-service-principal-client-id"
# client_secret = "your-service-principal-oauth-secret"

# ── Model endpoint (optional, defaults to databricks-claude-sonnet-4) ──
model_endpoint = "databricks-claude-sonnet-4"
